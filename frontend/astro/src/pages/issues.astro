---
import BaseLayout from '../layouts/BaseLayout.astro';
import InteractiveDashboard from '../components/InteractiveDashboard';
import type { BeaverData } from '../types/beaver';

// Load data generated by Go backend
let beaverData: BeaverData | null = null;
try {
  beaverData = await import('../data/beaver.json');
} catch (error) {
  console.warn('Beaver data not found, using placeholder data');
  beaverData = {
    issues: [],
    statistics: {
      total_issues: 0,
      open_issues: 0,
      closed_issues: 0,
      health_score: 0
    },
    navigation: { toc: [] },
    metadata: {
      generated_at: new Date().toISOString(),
      repository: 'example/repo',
      version: '1.0.0'
    }
  };
}

const { issues, statistics, metadata } = beaverData!;
---

<BaseLayout title="🦫 Beaver Issues - Interactive Dashboard" description="Interactive GitHub Issues Dashboard with Search and Analytics">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Hero Section -->
    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold mb-4 bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">
        🦫 Interactive Issues Dashboard
      </h1>
      <p class="text-lg text-gray-600 dark:text-gray-300">
        Advanced search, filtering, and analytics for GitHub Issues
      </p>
    </div>

    <!-- Repository Info Banner -->
    <div class="bg-gradient-to-r from-blue-50 to-purple-50 dark:from-blue-900/20 dark:to-purple-900/20 rounded-xl p-4 mb-8 border border-blue-200 dark:border-blue-800">
      <div class="flex items-center justify-between">
        <div class="flex items-center space-x-3">
          <div class="w-10 h-10 bg-gradient-to-br from-blue-600 to-purple-600 rounded-lg flex items-center justify-center">
            <span class="text-white font-bold">🦫</span>
          </div>
          <div>
            <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100">
              {metadata.repository}
            </h2>
            <p class="text-sm text-gray-600 dark:text-gray-400">
              Last updated: {new Date(metadata.generated_at).toLocaleString('ja-JP')}
            </p>
          </div>
        </div>
        <div class="flex items-center space-x-4 text-sm text-gray-600 dark:text-gray-400">
          <div class="text-center">
            <div class="font-bold text-blue-600">{issues.length}</div>
            <div>Total Issues</div>
          </div>
          <div class="text-center">
            <div class="font-bold text-green-600">{issues.filter(i => i.state === 'open').length}</div>
            <div>Open</div>
          </div>
          <div class="text-center">
            <div class="font-bold text-gray-600">{issues.filter(i => i.state === 'closed').length}</div>
            <div>Closed</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Interactive Dashboard Component -->
    <InteractiveDashboard 
      issues={issues} 
      statistics={statistics}
      client:load
    />

    <!-- Feature Information */
    <div class="mt-12 bg-white dark:bg-gray-800 rounded-xl p-8 shadow-sm border border-gray-200 dark:border-gray-700">
      <h3 class="text-xl font-bold mb-4 text-gray-900 dark:text-gray-100">
        🚀 Phase 2 Interactive Features
      </h3>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="space-y-2">
          <h4 class="font-semibold text-blue-600 dark:text-blue-400">🔍 Advanced Search</h4>
          <ul class="text-sm text-gray-600 dark:text-gray-400 space-y-1">
            <li>• Real-time text search</li>
            <li>• Search through titles and content</li>
            <li>• Case-insensitive matching</li>
            <li>• Instant results update</li>
          </ul>
        </div>
        
        <div class="space-y-2">
          <h4 class="font-semibold text-green-600 dark:text-green-400">🏷️ Smart Filtering</h4>
          <ul class="text-sm text-gray-600 dark:text-gray-400 space-y-1">
            <li>• Label-based filtering</li>
            <li>• State filtering (open/closed)</li>
            <li>• Urgency level filtering</li>
            <li>• Multi-criteria filtering</li>
          </ul>
        </div>
        
        <div class="space-y-2">
          <h4 class="font-semibold text-purple-600 dark:text-purple-400">📊 Interactive Analytics</h4>
          <ul class="text-sm text-gray-600 dark:text-gray-400 space-y-1">
            <li>• Dynamic statistics</li>
            <li>• Label distribution charts</li>
            <li>• Urgency analysis</li>
            <li>• Health score monitoring</li>
          </ul>
        </div>
        
        <div class="space-y-2">
          <h4 class="font-semibold text-red-600 dark:text-red-400">🎮 Interactive Controls</h4>
          <ul class="text-sm text-gray-600 dark:text-gray-400 space-y-1">
            <li>• Sortable columns</li>
            <li>• Pagination controls</li>
            <li>• Multi-select issues</li>
            <li>• View mode toggle</li>
          </ul>
        </div>
        
        <div class="space-y-2">
          <h4 class="font-semibold text-yellow-600 dark:text-yellow-400">⚡ Performance</h4>
          <ul class="text-sm text-gray-600 dark:text-gray-400 space-y-1">
            <li>• React Islands architecture</li>
            <li>• Optimized rendering</li>
            <li>• Client-side hydration</li>
            <li>• Responsive design</li>
          </ul>
        </div>
        
        <div class="space-y-2">
          <h4 class="font-semibold text-indigo-600 dark:text-indigo-400">🛠️ Technical Stack</h4>
          <ul class="text-sm text-gray-600 dark:text-gray-400 space-y-1">
            <li>• React 19 + TypeScript</li>
            <li>• Astro Islands</li>
            <li>• TailwindCSS styling</li>
            <li>• Static generation</li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Navigation -->
    <div class="mt-8 text-center">
      <a 
        href={import.meta.env.BASE_URL} 
        class="inline-flex items-center px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors shadow-sm"
      >
        ← Back to Home
      </a>
    </div>
  </div>
</BaseLayout>