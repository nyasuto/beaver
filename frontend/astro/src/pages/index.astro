---
import BaseLayout from '../layouts/BaseLayout.astro';
import type { BeaverData } from '../types/beaver';

// Load data generated by Go backend
let beaverData: BeaverData | null = null;
try {
  beaverData = await import('../data/beaver.json');
} catch (error) {
  console.warn('Beaver data not found, using placeholder data');
  beaverData = {
    issues: [],
    statistics: {
      total_issues: 0,
      open_issues: 0,
      closed_issues: 0,
      health_score: 0
    },
    navigation: { toc: [] },
    metadata: {
      generated_at: new Date().toISOString(),
      repository: 'example/repo',
      version: '1.0.0'
    }
  };
}

const { issues, statistics, metadata } = beaverData;
---

<BaseLayout title="🦫 Beaver - AI知識ダム" description="GitHub Issuesを構造化された知識ベースに変換">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Hero Section -->
    <div class="text-center mb-12">
      <h1 class="text-4xl font-bold mb-4 bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">
        🦫 Beaver AI知識ダム
      </h1>
      <p class="text-xl text-gray-600 dark:text-gray-300 mb-8">
        GitHub Issuesを永続的な知識ベースに変換
      </p>
      
      <!-- Statistics Dashboard -->
      <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
        <div class="bg-white dark:bg-gray-800 rounded-xl p-6 shadow-sm border border-gray-200 dark:border-gray-700">
          <div class="text-3xl font-bold text-blue-600 mb-2">{statistics.total_issues}</div>
          <div class="text-sm text-gray-600 dark:text-gray-400">Total Issues</div>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-xl p-6 shadow-sm border border-gray-200 dark:border-gray-700">
          <div class="text-3xl font-bold text-green-600 mb-2">{statistics.open_issues}</div>
          <div class="text-sm text-gray-600 dark:text-gray-400">Open</div>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-xl p-6 shadow-sm border border-gray-200 dark:border-gray-700">
          <div class="text-3xl font-bold text-gray-600 mb-2">{statistics.closed_issues}</div>
          <div class="text-sm text-gray-600 dark:text-gray-400">Closed</div>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-xl p-6 shadow-sm border border-gray-200 dark:border-gray-700">
          <div class="text-3xl font-bold text-purple-600 mb-2">{Math.round(statistics.health_score)}%</div>
          <div class="text-sm text-gray-600 dark:text-gray-400">Health Score</div>
        </div>
      </div>
    </div>

    <!-- Repository Info -->
    <div class="bg-white dark:bg-gray-800 rounded-xl p-8 shadow-sm border border-gray-200 dark:border-gray-700 mb-8">
      <h2 class="text-2xl font-bold mb-4">📊 Repository: {metadata.repository}</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 text-sm text-gray-600 dark:text-gray-400">
        <div>
          <span class="font-medium">Generated:</span> {new Date(metadata.generated_at).toLocaleString('ja-JP')}
        </div>
        <div>
          <span class="font-medium">Version:</span> {metadata.version}
        </div>
        <div>
          <span class="font-medium">Build:</span> {metadata.build_info?.build_time ? new Date(metadata.build_info.build_time).toLocaleString('ja-JP') : 'Unknown'}
        </div>
      </div>
    </div>

    <!-- Recent Issues -->
    {issues.length > 0 && (
      <div class="bg-white dark:bg-gray-800 rounded-xl p-8 shadow-sm border border-gray-200 dark:border-gray-700">
        <h2 class="text-2xl font-bold mb-6">🎯 Recent Issues</h2>
        <div class="space-y-4">
          {issues.slice(0, 5).map((issue) => (
            <div class="border border-gray-200 dark:border-gray-700 rounded-lg p-4 hover:shadow-md transition-shadow">
              <div class="flex items-start justify-between">
                <div class="flex-1">
                  <h3 class="font-semibold text-lg mb-2">
                    <a href={issue.html_url} target="_blank" rel="noopener noreferrer" 
                       class="text-blue-600 dark:text-blue-400 hover:underline">
                      #{issue.number} {issue.title}
                    </a>
                  </h3>
                  <div class="flex items-center space-x-4 text-sm text-gray-600 dark:text-gray-400 mb-2">
                    <span class={`px-2 py-1 rounded-full text-xs ${
                      issue.state === 'open' 
                        ? 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200' 
                        : 'bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300'
                    }`}>
                      {issue.state}
                    </span>
                    <span>by {issue.user.login}</span>
                    <span>{new Date(issue.created_at).toLocaleDateString('ja-JP')}</span>
                    {issue.analysis?.urgency_score && (
                      <span class={`px-2 py-1 rounded-full text-xs ${
                        issue.analysis.urgency_score > 50 
                          ? 'bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200'
                          : 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200'
                      }`}>
                        Urgency: {issue.analysis.urgency_score}
                      </span>
                    )}
                  </div>
                  {issue.labels.length > 0 && (
                    <div class="flex flex-wrap gap-2">
                      {issue.labels.map((label) => (
                        <span class="px-2 py-1 bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200 rounded-full text-xs">
                          {label}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
              </div>
            </div>
          ))}
        </div>
        
        {issues.length > 5 && (
          <div class="mt-6 text-center">
            <a href="/issues" class="inline-flex items-center px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors">
              View All Issues ({issues.length})
            </a>
          </div>
        )}
      </div>
    )}

    {issues.length === 0 && (
      <div class="bg-white dark:bg-gray-800 rounded-xl p-8 shadow-sm border border-gray-200 dark:border-gray-700 text-center">
        <div class="text-6xl mb-4">🦫</div>
        <h2 class="text-2xl font-bold mb-4">No Issues Found</h2>
        <p class="text-gray-600 dark:text-gray-400 mb-6">
          Run the Beaver build command to fetch and process GitHub Issues.
        </p>
        <div class="bg-gray-100 dark:bg-gray-700 rounded-lg p-4 font-mono text-sm">
          beaver build --astro-export
        </div>
      </div>
    )}
  </div>
</BaseLayout>