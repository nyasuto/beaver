---
import BaseLayout from '../layouts/BaseLayout.astro';
import StatisticsCard from '../components/StatisticsCard.astro';
import IssueCard from '../components/IssueCard.astro';
import DeveloperDashboard from '../components/DeveloperDashboard';
import CoverageSummaryWidget from '../components/Coverage/CoverageSummaryWidget.astro';
import type { BeaverData } from '../types/beaver';

// Load data generated by Go backend
let beaverData: BeaverData | null = null;
try {
  beaverData = await import('../data/beaver.json');
} catch (error) {
  console.warn('Beaver data not found, using placeholder data');
  beaverData = {
    issues: [],
    statistics: {
      total_issues: 0,
      open_issues: 0,
      closed_issues: 0,
      health_score: 0
    },
    navigation: { toc: [] },
    metadata: {
      generated_at: new Date().toISOString(),
      repository: 'example/repo',
      version: '1.0.0'
    }
  };
}

const { issues, statistics, metadata } = beaverData!;

// Load coverage data for quality summary
let coverageData: any = null;
try {
  // During build: try to read from public/coverage directory
  // During runtime: fetch from the served URL
  if (import.meta.env.DEV || !import.meta.env.PROD) {
    // Development mode: use fetch
    const response = await fetch('/beaver/coverage/coverage-data.json');
    if (response.ok) {
      coverageData = await response.json();
    }
  } else {
    // Build time: try to import from file system first, then fallback to fetch
    try {
      const fs = await import('fs');
      const path = await import('path');
      const coverageFile = path.resolve(process.cwd(), 'public/coverage/coverage-data.json');
      if (fs.existsSync(coverageFile)) {
        const rawData = fs.readFileSync(coverageFile, 'utf8');
        coverageData = JSON.parse(rawData);
        console.log('✅ Coverage data loaded from build-time file system');
      } else {
        // Fallback to fetch for runtime
        const response = await fetch('/beaver/coverage/coverage-data.json');
        if (response.ok) {
          coverageData = await response.json();
          console.log('✅ Coverage data loaded from runtime fetch');
        }
      }
    } catch (fsError) {
      // Final fallback to fetch
      console.warn('File system access failed, trying fetch:', fsError);
      const response = await fetch('/beaver/coverage/coverage-data.json');
      if (response.ok) {
        coverageData = await response.json();
      }
    }
  }
} catch (error) {
  console.warn('Coverage data not available:', error);
}

// Calculate quality metrics from coverage data
const coveragePercentage = coverageData?.total_coverage !== undefined ? Math.round(coverageData.total_coverage * 10) / 10 : 'NO_COVERAGE';
const qualityGrade = coverageData?.quality_grade || 'NO_GRADE';
const untestedCount = coverageData?.summary?.untested_packages !== undefined ? coverageData.summary.untested_packages : 'NO_DATA';
const targetCoverage = 70.0;
---

<BaseLayout title="🦫 Beaver AI知識ダム" description="GitHub Issuesを永続的な知識ベースに変換">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Enhanced Hero Section -->
    <div class="text-center mb-12">
      <h1 class="text-6xl font-bold mb-6 bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">
        🦫 Beaver AI知識ダム
      </h1>
      <p class="text-2xl text-gray-600 dark:text-gray-300 mb-8">
        GitHub Issuesを永続的な知識ベースに変換
      </p>
      
      <!-- Simple Navigation -->
      <div class="flex gap-6 justify-center items-center mb-6">
        <a 
          href={import.meta.env.BASE_URL} 
          class="text-lg text-gray-600 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 transition-colors font-medium"
        >
          🏠 ホーム
        </a>
        <a 
          href={`${import.meta.env.BASE_URL}issues`} 
          class="text-lg text-gray-600 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 transition-colors font-medium"
        >
          🔍 サーチ
        </a>
        <a 
          href={`${import.meta.env.BASE_URL}beaver-facts`} 
          class="text-lg text-gray-600 dark:text-gray-300 hover:text-green-600 dark:hover:text-green-400 transition-colors font-medium"
        >
          🦫 About Beavers
        </a>
      </div>
    </div>

    <!-- Enhanced Today's Actions Section with 3 parallel components -->
    <div class="bg-gradient-to-r from-blue-50 to-purple-50 dark:from-blue-900/20 dark:to-purple-900/20 rounded-xl p-6 border border-blue-200 dark:border-blue-800 mb-8">
      <div class="flex items-center justify-between mb-6">
        <h3 class="text-lg font-semibold text-blue-900 dark:text-blue-100">
          🎯 今日のアクション
        </h3>
        <div class="text-sm text-blue-700 dark:text-blue-300">
          {new Date().toLocaleDateString('ja-JP', { 
            weekday: 'long', 
            year: 'numeric', 
            month: 'long', 
            day: 'numeric' 
          })}
        </div>
      </div>
      
      <!-- 3 Column Layout within Today's Actions -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Recommended Actions -->
        <div class="bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 p-4">
          <div class="flex items-center mb-3">
            <span class="text-lg mr-2">📋</span>
            <h4 class="font-medium text-blue-800 dark:text-blue-200">推奨アクション</h4>
          </div>
          <div class="space-y-3">
            <div class="bg-blue-50 dark:bg-blue-900/20 rounded-md p-3 border-l-4 border-blue-500">
              <div class="text-sm text-blue-700 dark:text-blue-300 font-medium">
                🚨 3件の緊急対応が必要
              </div>
            </div>
            <div class="bg-blue-50 dark:bg-blue-900/20 rounded-md p-3 border-l-4 border-blue-500">
              <div class="text-sm text-blue-700 dark:text-blue-300 font-medium">
                ✨ 10件の新機能実装待ち
              </div>
            </div>
          </div>
        </div>
        
        <!-- Quality Overview -->
        <div class="bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 p-4">
          <div class="flex items-center mb-3">
            <span class="text-lg mr-2">🧪</span>
            <h4 class="font-medium text-red-800 dark:text-red-200">品質概要</h4>
          </div>
          <div class="border-l-4 border-red-500 bg-red-50 dark:bg-red-900/20 rounded-lg p-3">
            <div class="flex items-center justify-between mb-2">
              <div class="flex items-center space-x-2">
                <span class="text-sm">⚠️</span>
                <div>
                  <div class="text-sm font-medium text-red-800 dark:text-red-200">
                    カバレッジ {coveragePercentage}% ({qualityGrade}評価)
                  </div>
                  <div class="text-xs text-red-600 dark:text-red-300">
                    カバレッジ向上が必要
                  </div>
                </div>
              </div>
              <span class="inline-flex items-center px-2 py-1 rounded text-xs font-medium bg-red-600 text-white">
                🚨 1件緊急
              </span>
            </div>
            
            <div class="grid grid-cols-3 gap-2 mb-2 text-xs">
              <div class="text-center">
                <div class="font-bold">{coveragePercentage}%</div>
                <div class="opacity-75">カバレッジ</div>
              </div>
              <div class="text-center">
                <div class="font-bold">{targetCoverage}%</div>
                <div class="opacity-75">目標</div>
              </div>
              <div class="text-center">
                <div class="font-bold">{untestedCount}</div>
                <div class="opacity-75">未テスト</div>
              </div>
            </div>
            
            <div class="w-full bg-red-200 dark:bg-red-800 rounded-full h-1.5 mb-2">
              <div class="h-1.5 bg-red-500 rounded-full" style={`width: ${typeof coveragePercentage === 'number' ? coveragePercentage : 0}%`}></div>
            </div>
            
            <div class="flex items-center justify-between">
              <a 
                href="/beaver/coverage" 
                class="text-xs font-medium text-red-700 dark:text-red-300 hover:text-red-900 dark:hover:text-red-100 transition-colors"
              >
                📊 詳細分析
              </a>
              <button class="inline-flex items-center px-2 py-1 text-xs font-medium text-white bg-red-600 hover:bg-red-700 rounded transition-colors">
                🚀 改善開始
              </button>
            </div>
          </div>
        </div>
        
        <!-- Progress Summary -->
        <div class="bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 p-4">
          <div class="flex items-center mb-3">
            <span class="text-lg mr-2">📊</span>
            <h4 class="font-medium text-gray-800 dark:text-gray-200">進捗サマリー</h4>
          </div>
          <div class="space-y-4">
            <!-- Daily Progress -->
            <div>
              <div class="text-sm font-medium text-green-700 dark:text-green-300 mb-2">
                🌟 本日（24h）
              </div>
              <div class="grid grid-cols-3 gap-1 text-xs">
                <div class="text-center p-2 bg-green-50 dark:bg-green-900/20 rounded">
                  <div class="font-bold text-green-600">22</div>
                  <div class="text-gray-600 dark:text-gray-400">新規</div>
                </div>
                <div class="text-center p-2 bg-blue-50 dark:bg-blue-900/20 rounded">
                  <div class="font-bold text-blue-600">28</div>
                  <div class="text-gray-600 dark:text-gray-400">更新</div>
                </div>
                <div class="text-center p-2 bg-purple-50 dark:bg-purple-900/20 rounded">
                  <div class="font-bold text-purple-600">24</div>
                  <div class="text-gray-600 dark:text-gray-400">完了</div>
                </div>
              </div>
            </div>
            
            <!-- Weekly Progress -->
            <div>
              <div class="text-sm font-medium text-blue-700 dark:text-blue-300 mb-2">
                📈 今週
              </div>
              <div class="grid grid-cols-2 gap-2 text-xs">
                <div class="text-center p-2 bg-gray-50 dark:bg-gray-700 rounded border">
                  <div class="font-bold text-green-600">{statistics.workflow_metrics?.new_this_week || 115}</div>
                  <div class="text-gray-600 dark:text-gray-400">新規</div>
                </div>
                <div class="text-center p-2 bg-gray-50 dark:bg-gray-700 rounded border">
                  <div class="font-bold text-blue-600">{statistics.workflow_metrics?.closed_this_week || 122}</div>
                  <div class="text-gray-600 dark:text-gray-400">完了</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Developer Dashboard (Issue #367) -->
    {issues.length > 0 && (
      <DeveloperDashboard 
        issues={issues} 
        statistics={statistics}
        client:load
        className="mb-12"
      />
    )}

    <!-- Repository Info -->
    <div class="bg-white dark:bg-gray-800 rounded-xl p-8 shadow-sm border border-gray-200 dark:border-gray-700 mb-8">
      <h2 class="text-2xl font-bold mb-4">📊 Repository: {metadata.repository}</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 text-sm text-gray-600 dark:text-gray-400">
        <div>
          <span class="font-medium">Generated:</span> {new Date(metadata.generated_at).toLocaleString('ja-JP')}
        </div>
        <div>
          <span class="font-medium">Version:</span> {metadata.version}
        </div>
        <div>
          <span class="font-medium">Build:</span> {metadata.build_info?.build_time ? new Date(metadata.build_info.build_time).toLocaleString('ja-JP') : 'Unknown'}
        </div>
      </div>
    </div>

    <!-- Recent Issues with Enhanced Components -->
    {issues.length > 0 && (
      <div class="bg-white dark:bg-gray-800 rounded-xl p-8 shadow-sm border border-gray-200 dark:border-gray-700">
        <h2 class="text-2xl font-bold mb-6">🎯 Recent Issues</h2>
        <div class="space-y-4">
          {issues.slice(0, 5).map((issue) => (
            <IssueCard issue={issue} showAnalysis={true} compact={false} />
          ))}
        </div>
        
        {issues.length > 5 && (
          <div class="mt-6 text-center">
            <a href={`${import.meta.env.BASE_URL}issues`} class="inline-flex items-center px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors">
              View All Issues ({issues.length})
            </a>
          </div>
        )}
      </div>
    )}

    {issues.length === 0 && (
      <div class="bg-white dark:bg-gray-800 rounded-xl p-8 shadow-sm border border-gray-200 dark:border-gray-700 text-center">
        <div class="text-6xl mb-4">🦫</div>
        <h2 class="text-2xl font-bold mb-4">No Issues Found</h2>
        <p class="text-gray-600 dark:text-gray-400 mb-6">
          Run the Beaver build command to fetch and process GitHub Issues.
        </p>
        <div class="bg-gray-100 dark:bg-gray-700 rounded-lg p-4 font-mono text-sm">
          beaver build --astro-export
        </div>
      </div>
    )}
  </div>
</BaseLayout>