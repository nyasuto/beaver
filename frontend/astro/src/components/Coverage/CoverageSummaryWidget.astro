---
import type { CoverageData } from '../../types/beaver';

interface Props {
  className?: string;
}

const { className = '' } = Astro.props;

// Try to load coverage data dynamically
let coverageData: CoverageData | null = null;
let isDataAvailable = false;

try {
  // Try to fetch real coverage data first
  const response = await fetch('/beaver/coverage/coverage-data.json');
  if (response.ok) {
    const realData = await response.json();
    // Transform the real data to match CoverageData interface
    coverageData = {
      project_name: realData.project_name || 'beaver',
      generated_at: realData.generated_at || new Date().toISOString(),
      total_coverage: realData.total_coverage || -1, // NO_COVERAGE indicator
      quality_rating: {
        overall_grade: realData.quality_grade || 'NO_GRADE',
        description: 'カバレッジデータ取得エラー',
        next_target: 70.0
      },
      summary: {
        total_packages: realData.summary?.total_packages || -1,
        tested_packages: realData.summary?.tested_packages || -1,
        untested_packages: realData.summary?.untested_packages || -1,
        total_files: realData.summary?.total_files || -1,
        tested_files: realData.summary?.tested_files || -1
      },
      package_stats: [],
      file_coverage: [],
      recommendations: [
        {
          priority: 'High',
          title: 'テストカバレッジの向上',
          description: '基本的なユニットテストの追加が必要です'
        }
      ]
    };
    isDataAvailable = true;
  } else {
    // Fallback to mock data
    coverageData = {
      project_name: 'beaver',
      generated_at: new Date().toISOString(),
      total_coverage: -1, // NO_COVERAGE indicator
      quality_rating: {
        overall_grade: 'NO_GRADE',
        description: 'カバレッジデータが利用できません',
        next_target: 70.0
      },
      summary: {
        total_packages: -1,
        tested_packages: -1,
        untested_packages: -1,
        total_files: -1,
        tested_files: -1
      },
      package_stats: [],
      file_coverage: [],
      recommendations: [
        {
          priority: 'High',
          title: 'テストカバレッジの向上',
          description: '基本的なユニットテストの追加が必要です'
        }
      ]
    };
    isDataAvailable = true;
  }
} catch (error) {
  isDataAvailable = false;
}

// Grade color mapping
const getGradeColor = (grade: string) => {
  const colors = {
    'A': 'text-green-600 dark:text-green-400 bg-green-50 dark:bg-green-900/20 border-green-200 dark:border-green-800',
    'B': 'text-lime-600 dark:text-lime-400 bg-lime-50 dark:bg-lime-900/20 border-lime-200 dark:border-lime-800',
    'C': 'text-orange-600 dark:text-orange-400 bg-orange-50 dark:bg-orange-900/20 border-orange-200 dark:border-orange-800',
    'D': 'text-red-600 dark:text-red-400 bg-red-50 dark:bg-red-900/20 border-red-200 dark:border-red-800',
    'F': 'text-red-700 dark:text-red-500 bg-red-100 dark:bg-red-900/30 border-red-300 dark:border-red-700'
  };
  return colors[grade as keyof typeof colors] || 'text-gray-600 dark:text-gray-400 bg-gray-50 dark:bg-gray-900/20 border-gray-200 dark:border-gray-800';
};
---

<div class={`bg-white dark:bg-gray-800 rounded-xl shadow-lg border border-gray-200 dark:border-gray-700 ${className}`}>
  <div class="p-6">
    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
      <div class="flex items-center space-x-3">
        <div class="p-2 bg-gradient-to-br from-blue-100 to-purple-100 dark:from-blue-900/30 dark:to-purple-900/30 rounded-lg">
          <span class="text-2xl">📊</span>
        </div>
        <div>
          <h3 class="text-lg font-bold text-gray-800 dark:text-white">
            品質概要
          </h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            テスト品質とカバレッジ状況
          </p>
        </div>
      </div>
      <a 
        href="/beaver/coverage" 
        class="inline-flex items-center px-3 py-1.5 text-sm font-medium text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 transition-colors"
      >
        詳細を見る →
      </a>
    </div>

    {isDataAvailable && coverageData ? (
      <div class="space-y-6">
        <!-- Main Metrics -->
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
          <!-- Total Coverage -->
          <div class="text-center">
            <div class={`text-2xl font-bold mb-1 ${getGradeColor(coverageData.quality_rating.overall_grade).split(' ')[0]}`}>
              {coverageData.total_coverage >= 0 ? coverageData.total_coverage.toFixed(1) + '%' : 'NO_COVERAGE'}
            </div>
            <div class="text-xs text-gray-600 dark:text-gray-400">
              総合カバレッジ
            </div>
          </div>

          <!-- Quality Grade -->
          <div class="text-center">
            <div class={`text-2xl font-bold mb-1 ${getGradeColor(coverageData.quality_rating.overall_grade).split(' ')[0]}`}>
              {coverageData.quality_rating.overall_grade}
            </div>
            <div class="text-xs text-gray-600 dark:text-gray-400">
              品質評価
            </div>
          </div>

          <!-- Packages -->
          <div class="text-center">
            <div class="text-2xl font-bold mb-1 text-blue-600 dark:text-blue-400">
              {coverageData.summary.total_packages >= 0 ? coverageData.summary.total_packages : 'NO_DATA'}
            </div>
            <div class="text-xs text-gray-600 dark:text-gray-400">
              パッケージ
            </div>
          </div>

          <!-- Issues -->
          <div class="text-center">
            <div class="text-2xl font-bold mb-1 text-red-600 dark:text-red-400">
              {coverageData.recommendations.filter(r => r.priority === 'High').length}
            </div>
            <div class="text-xs text-gray-600 dark:text-gray-400">
              緊急課題
            </div>
          </div>
        </div>

        <!-- Progress Bar -->
        <div class="space-y-2">
          <div class="flex justify-between text-sm text-gray-600 dark:text-gray-400">
            <span>進捗: {coverageData.total_coverage >= 0 ? coverageData.total_coverage.toFixed(1) + '%' : 'NO_COVERAGE'}</span>
            <span>目標: {coverageData.quality_rating.next_target.toFixed(1)}%</span>
          </div>
          <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-full h-2">
            <div 
              class={`h-2 rounded-full transition-all duration-300 ${
                coverageData.quality_rating.overall_grade === 'A' ? 'bg-green-500' :
                coverageData.quality_rating.overall_grade === 'B' ? 'bg-lime-500' :
                coverageData.quality_rating.overall_grade === 'C' ? 'bg-orange-500' :
                coverageData.quality_rating.overall_grade === 'D' ? 'bg-red-500' : 'bg-red-600'
              }`}
              style={`width: ${coverageData.total_coverage >= 0 ? Math.min(coverageData.total_coverage, 100) : 0}%`}
            ></div>
          </div>
          <div class="text-xs text-gray-500 dark:text-gray-400 text-center">
            {coverageData.total_coverage >= 0 ? 
              `目標まで あと ${Math.max(0, coverageData.quality_rating.next_target - coverageData.total_coverage).toFixed(1)}%` :
              'データ利用不可'
            }
          </div>
        </div>

        <!-- Quick Insights -->
        <div class={`p-4 rounded-lg border ${getGradeColor(coverageData.quality_rating.overall_grade)}`}>
          <div class="flex items-start space-x-3">
            <div class="flex-shrink-0 mt-0.5">
              {coverageData.quality_rating.overall_grade === 'A' ? '🎉' :
               coverageData.quality_rating.overall_grade === 'B' ? '👍' :
               coverageData.quality_rating.overall_grade === 'C' ? '📈' :
               coverageData.quality_rating.overall_grade === 'D' ? '⚠️' : '🚨'}
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium">
                {coverageData.quality_rating.description}
              </p>
              <p class="text-xs mt-1 opacity-75">
                最終更新: {new Date(coverageData.generated_at).toLocaleDateString('ja-JP')}
              </p>
            </div>
          </div>
        </div>

        <!-- Action Items -->
        {coverageData.recommendations.length > 0 && (
          <div class="space-y-2">
            <h4 class="text-sm font-semibold text-gray-800 dark:text-white">
              🚀 推奨アクション
            </h4>
            <div class="space-y-2">
              {coverageData.recommendations.slice(0, 2).map((rec) => (
                <div class="flex items-center space-x-2 text-sm">
                  <div class={`w-2 h-2 rounded-full ${
                    rec.priority === 'High' ? 'bg-red-500' :
                    rec.priority === 'Medium' ? 'bg-orange-500' : 'bg-green-500'
                  }`}></div>
                  <span class="text-gray-700 dark:text-gray-300 truncate">
                    {rec.title}
                  </span>
                </div>
              ))}
              {coverageData.recommendations.length > 2 && (
                <div class="text-xs text-gray-500 dark:text-gray-400 ml-4">
                  +{coverageData.recommendations.length - 2} その他の提案
                </div>
              )}
            </div>
          </div>
        )}
      </div>
    ) : (
      <!-- No Data State -->
      <div class="text-center py-8">
        <div class="text-4xl mb-3">📊</div>
        <h4 class="text-sm font-medium text-gray-800 dark:text-white mb-2">
          カバレッジデータなし
        </h4>
        <p class="text-xs text-gray-600 dark:text-gray-400 mb-4">
          テストを実行してカバレッジデータを生成してください
        </p>
        <a 
          href="/beaver/coverage" 
          class="inline-flex items-center px-3 py-1.5 text-xs font-medium text-white bg-blue-600 hover:bg-blue-700 rounded-lg transition-colors"
        >
          📊 カバレッジ分析を開始
        </a>
      </div>
    )}
  </div>
</div>