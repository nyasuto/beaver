---
import type { CoverageTableProps } from '../../types/beaver';

interface Props extends CoverageTableProps {}

const { packages, type, limit = 5, className = '' } = Astro.props;

// Apply limit and sort
const displayPackages = packages.slice(0, limit);

// Grade color mapping
const getGradeColor = (grade: string) => {
  const colors = {
    'A': 'text-green-600 dark:text-green-400 bg-green-50 dark:bg-green-900/20',
    'B': 'text-lime-600 dark:text-lime-400 bg-lime-50 dark:bg-lime-900/20', 
    'C': 'text-orange-600 dark:text-orange-400 bg-orange-50 dark:bg-orange-900/20',
    'D': 'text-red-600 dark:text-red-400 bg-red-50 dark:bg-red-900/20',
    'F': 'text-red-700 dark:text-red-500 bg-red-100 dark:bg-red-900/30'
  };
  return colors[grade as keyof typeof colors] || 'text-gray-600 dark:text-gray-400 bg-gray-50 dark:bg-gray-900/20';
};

// Format package name for display
const formatPackageName = (name: string) => {
  const parts = name.split('/');
  if (parts.length <= 3) return name;
  
  // Show first part and last 2 parts
  const first = parts[0];
  const last = parts.slice(-2).join('/');
  return `${first}/.../${last}`;
};
---

<div class={`overflow-hidden ${className}`}>
  {displayPackages.length > 0 ? (
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead class="bg-gray-50 dark:bg-gray-700">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
              パッケージ
            </th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
              カバレッジ
            </th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
              評価
            </th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
              詳細
            </th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 dark:divide-gray-600">
          {displayPackages.map((pkg, index) => {
            const gradeColor = getGradeColor(pkg.quality_grade);
            const coverageBarWidth = Math.min(pkg.coverage, 100);
            
            return (
              <tr 
                class={`hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors ${
                  index % 2 === 0 ? 'bg-white dark:bg-gray-800' : 'bg-gray-50 dark:bg-gray-750'
                }`}
              >
                <!-- Package Name -->
                <td class="px-4 py-4">
                  <div class="text-sm">
                    <div 
                      class="font-medium text-gray-900 dark:text-white truncate max-w-xs"
                      title={pkg.package_name}
                    >
                      {formatPackageName(pkg.package_name)}
                    </div>
                    <div class="text-gray-500 dark:text-gray-400 text-xs">
                      {pkg.file_count} ファイル
                    </div>
                  </div>
                </td>

                <!-- Coverage with Progress Bar -->
                <td class="px-4 py-4">
                  <div class="text-sm">
                    <div class="font-medium text-gray-900 dark:text-white">
                      {pkg.coverage.toFixed(1)}%
                    </div>
                    <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-full h-2 mt-1">
                      <div 
                        class={`h-2 rounded-full transition-all duration-300 ${
                          pkg.quality_grade === 'A' ? 'bg-green-500' :
                          pkg.quality_grade === 'B' ? 'bg-lime-500' :
                          pkg.quality_grade === 'C' ? 'bg-orange-500' :
                          pkg.quality_grade === 'D' ? 'bg-red-500' : 'bg-red-600'
                        }`}
                        style={`width: ${coverageBarWidth}%`}
                      ></div>
                    </div>
                  </div>
                </td>

                <!-- Grade Badge -->
                <td class="px-4 py-4">
                  <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${gradeColor}`}>
                    {pkg.quality_grade}
                  </span>
                </td>

                <!-- Statement Details -->
                <td class="px-4 py-4">
                  <div class="text-sm text-gray-600 dark:text-gray-400">
                    <div>
                      {pkg.covered_statements}/{pkg.total_statements}
                    </div>
                    <div class="text-xs text-gray-500 dark:text-gray-500">
                      statements
                    </div>
                  </div>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  ) : (
    <!-- Empty State -->
    <div class="text-center py-8">
      <div class="text-gray-400 dark:text-gray-600 text-4xl mb-4">
        {type === 'top-performers' ? '🏆' : '⚠️'}
      </div>
      <div class="text-gray-600 dark:text-gray-400">
        {type === 'top-performers' 
          ? 'まだ高パフォーマンスパッケージがありません' 
          : '改善が必要なパッケージはありません'
        }
      </div>
    </div>
  )}

  <!-- Action Buttons -->
  {displayPackages.length > 0 && (
    <div class="mt-4 flex justify-between items-center text-sm">
      <div class="text-gray-500 dark:text-gray-400">
        {displayPackages.length}件表示
        {limit < packages.length && ` (全${packages.length}件中)`}
      </div>
      
      {type === 'needs-attention' && (
        <div class="flex space-x-2">
          <button class="inline-flex items-center px-3 py-1.5 border border-gray-300 dark:border-gray-600 text-xs font-medium rounded text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
            📊 詳細分析
          </button>
          <button class="inline-flex items-center px-3 py-1.5 border border-transparent text-xs font-medium rounded text-white bg-red-600 hover:bg-red-700 transition-colors">
            🚀 改善計画
          </button>
        </div>
      )}
      
      {type === 'top-performers' && (
        <div class="flex space-x-2">
          <button class="inline-flex items-center px-3 py-1.5 border border-gray-300 dark:border-gray-600 text-xs font-medium rounded text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
            📋 パターン分析
          </button>
          <button class="inline-flex items-center px-3 py-1.5 border border-transparent text-xs font-medium rounded text-white bg-green-600 hover:bg-green-700 transition-colors">
            ✨ ベストプラクティス
          </button>
        </div>
      )}
    </div>
  )}
</div>

<!-- Table Summary -->
{displayPackages.length > 0 && (
  <div class="mt-6 p-4 bg-gray-50 dark:bg-gray-700 rounded-lg">
    <h4 class="text-sm font-medium text-gray-800 dark:text-white mb-2">
      {type === 'top-performers' ? '🏆 高パフォーマンス要因' : '⚠️ 改善ポイント'}
    </h4>
    <div class="text-sm text-gray-600 dark:text-gray-400">
      {type === 'top-performers' ? (
        <ul class="space-y-1">
          <li>• 包括的なテストカバレッジ</li>
          <li>• 継続的な品質管理</li>
          <li>• 適切なテスト設計</li>
        </ul>
      ) : (
        <ul class="space-y-1">
          <li>• 基本的なテストケース追加</li>
          <li>• エッジケースのカバレッジ向上</li>
          <li>• テスト戦略の見直し</li>
        </ul>
      )}
    </div>
  </div>
)}