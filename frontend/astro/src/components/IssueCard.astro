---
// Phase 1: Issue Card Component
// Replaces inline issue rendering with reusable component

import type { Issue } from '../types/beaver';

export interface Props {
  issue: Issue;
  showAnalysis?: boolean;
  compact?: boolean;
  className?: string;
}

const { issue, showAnalysis = true, compact = false, className = '' } = Astro.props;

// Helper functions
function formatDate(dateString: string): string {
  const date = new Date(dateString);
  return date.toLocaleDateString('ja-JP', {
    year: 'numeric',
    month: 'numeric',
    day: 'numeric'
  });
}

function getStateColor(state: string): string {
  return state === 'open' 
    ? 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200'
    : 'bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300';
}

function getUrgencyColor(urgency: number): string {
  if (urgency >= 50) return 'bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200';
  if (urgency >= 30) return 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200';
  if (urgency >= 10) return 'bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200';
  return 'bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300';
}

function getPriorityLabel(labels: string[]): string {
  const priorityLabel = labels.find(label => label.startsWith('priority:'));
  return priorityLabel ? priorityLabel.replace('priority:', '').trim() : '';
}
---

<div class={`border border-gray-200 dark:border-gray-700 rounded-lg p-4 hover:shadow-md transition-shadow ${compact ? 'py-2' : ''} ${className}`}>
  <div class="flex items-start justify-between">
    <div class="flex-1">
      <!-- Title and Issue Number -->
      <h3 class={`font-semibold ${compact ? 'text-base' : 'text-lg'} mb-2`}>
        <a 
          href={issue.html_url} 
          target="_blank" 
          rel="noopener noreferrer" 
          class="text-blue-600 dark:text-blue-400 hover:underline"
        >
          #{issue.number} {issue.title}
        </a>
      </h3>

      <!-- Issue Metadata -->
      <div class={`flex items-center space-x-4 text-sm text-gray-600 dark:text-gray-400 ${compact ? 'mb-1' : 'mb-2'}`}>
        <!-- State -->
        <span class={`px-2 py-1 rounded-full text-xs ${getStateColor(issue.state)}`}>
          {issue.state}
        </span>
        
        <!-- Author and Date -->
        <span>by {issue.user.login}</span>
        <span>{formatDate(issue.created_at)}</span>
        
        <!-- Urgency Score (if available and showAnalysis is true) -->
        {showAnalysis && issue.analysis?.urgency_score && (
          <span class={`px-2 py-1 rounded-full text-xs ${getUrgencyColor(issue.analysis.urgency_score)}`}>
            Urgency: {issue.analysis.urgency_score}
          </span>
        )}
      </div>

      <!-- Labels -->
      {issue.labels && issue.labels.length > 0 && (
        <div class="flex flex-wrap gap-2">
          {issue.labels.map((label) => {
            const priority = getPriorityLabel([label]);
            const isPriority = label.startsWith('priority:');
            return (
              <span 
                key={label}
                class={`px-2 py-1 rounded-full text-xs ${
                  isPriority 
                    ? 'bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200'
                    : 'bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300'
                }`}
              >
                {label}
              </span>
            );
          })}
        </div>
      )}

      <!-- Analysis Information (if available and not compact) -->
      {!compact && showAnalysis && issue.analysis && (
        <div class="mt-3 p-3 bg-gray-50 dark:bg-gray-800 rounded-md">
          <div class="text-sm">
            {issue.analysis.category && (
              <div class="mb-1">
                <span class="font-medium text-gray-700 dark:text-gray-300">Category:</span>
                <span class="ml-2 text-gray-600 dark:text-gray-400">{issue.analysis.category}</span>
              </div>
            )}
            {issue.analysis.tags && issue.analysis.tags.length > 0 && (
              <div>
                <span class="font-medium text-gray-700 dark:text-gray-300">Tags:</span>
                <span class="ml-2 text-gray-600 dark:text-gray-400">
                  {issue.analysis.tags.join(', ')}
                </span>
              </div>
            )}
          </div>
        </div>
      )}

      <!-- Issue Body Preview (if not compact) -->
      {!compact && issue.body && (
        <div class="mt-3">
          <p class="text-gray-600 dark:text-gray-400 text-sm line-clamp-2">
            {issue.body.length > 150 
              ? issue.body.substring(0, 150) + '...' 
              : issue.body
            }
          </p>
        </div>
      )}
    </div>

    <!-- Quick Actions (could be expanded in Phase 2) -->
    <div class="flex-shrink-0 ml-4">
      <a 
        href={issue.html_url}
        target="_blank"
        rel="noopener noreferrer"
        class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors"
        title="Open in GitHub"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
        </svg>
      </a>
    </div>
  </div>
</div>