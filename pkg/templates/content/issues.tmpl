{{/* Issues content template */}}
{{- $issues := .Issues -}}
{{- $context := .Context -}}
{{- $meta := .Meta -}}

{{- if eq $context.Format "html" -}}
<div class="issues-container">
    <div class="issues-header">
        <h1>{{$meta.Title}}</h1>
        <p class="issues-description">{{$meta.Description}}</p>
        
        <div class="issues-stats">
            <div class="stat-item">
                <span class="stat-number">{{len $issues}}</span>
                <span class="stat-label">Total Issues</span>
            </div>
            <div class="stat-item">
                <span class="stat-number">{{countByState $issues "open"}}</span>
                <span class="stat-label">Open</span>
            </div>
            <div class="stat-item">
                <span class="stat-number">{{countByState $issues "closed"}}</span>
                <span class="stat-label">Closed</span>
            </div>
        </div>
    </div>
    
    <div class="issues-filters">
        <button class="filter-btn active" data-filter="all">All</button>
        <button class="filter-btn" data-filter="open">Open</button>
        <button class="filter-btn" data-filter="closed">Closed</button>
    </div>
    
    <div class="issues-list">
        {{range $issues}}
        <article class="issue-card" data-state="{{.State}}">
            <div class="issue-header">
                <h2 class="issue-title">
                    <a href="{{.HTMLURL}}" target="_blank">#{{.Number}} {{.Title}}</a>
                </h2>
                <div class="issue-meta">
                    <span class="issue-state issue-state-{{.State}}">{{.State}}</span>
                    <span class="issue-author">{{.User.Login}}</span>
                    <time class="issue-date">{{formatDate .CreatedAt}}</time>
                </div>
            </div>
            
            {{if .Body}}
            <div class="issue-body">
                <p>{{truncate .Body 200}}</p>
            </div>
            {{end}}
            
            {{if .Labels}}
            <div class="issue-labels">
                {{range .Labels}}
                <span class="label" style="background-color: #{{.Color}};">{{.Name}}</span>
                {{end}}
            </div>
            {{end}}
        </article>
        {{end}}
    </div>
</div>
{{- else if eq $context.Format "markdown" -}}
# {{$meta.Title}}

{{$meta.Description}}

## Statistics

- **Total Issues**: {{len $issues}}
- **Open Issues**: {{countByState $issues "open"}}
- **Closed Issues**: {{countByState $issues "closed"}}

## Issues List

{{range $issues}}
### [#{{.Number}} {{.Title}}]({{.HTMLURL}})

**Status**: {{.State}} | **Author**: {{.User.Login}} | **Created**: {{formatDate .CreatedAt}}

{{if .Body}}{{truncate .Body 300}}{{end}}

{{if .Labels}}**Labels**: {{range .Labels}}{{.Name}}, {{end}}{{end}}

---

{{end}}
{{- end -}}